---
import Layout from '../layouts/Layout.astro';
import wave from '../data/wave-2026.json';
import IndicesChart from '../components/IndicesChart.astro';
import ViewToggle from '../components/ViewToggle.astro';

const w = wave.wave;
const dims = [...new Set(wave.indices.map((i) => i.dimension))];
const inm = wave.indices.find((i) => i.code === 'ІНМ');
const fmtN = (n: number) => n.toLocaleString('uk-UA');
const byDim = (dim: string) => wave.indices.filter((i) => i.dimension === dim);
---

<Layout
  title={`Науковий Барометр — ${w.label}`}
  description="Інтерсуб'єктивні індекси якості наукової діяльності в Україні. Пілотне дослідження N=200."
>
  <h1>Науковий Барометр</h1>
  <p class="sub">
    Індекси якості наукової діяльності в Україні · {w.label}<span class="pilot">пілот N={w.n}</span>
  </p>

  <div class="meta">
    <p>
      <b>Поле:</b> {w.field.start} – {w.field.end} ({w.field.days} днів). <b>Генеральна сукупність:</b>
      {fmtN(w.population.size)} ({w.population.source}); вибірка — {w.population.fractionPct}%.
      <b>Відбір:</b> невипадковий (зручний/самовідбір). Докладніше — <a href="/methodology">методологія</a>.
    </p>
  </div>

  {
    dims.map((dim, i) => {
      const items = byDim(dim);
      return (
        <section>
          <h2>{dim}</h2>
          <ViewToggle id={`dim-${i}`}>
            <IndicesChart slot="chart" indices={items} />
            <table slot="table">
              <thead>
                <tr>
                  <th>Індекс</th>
                  <th>Опис</th>
                  <th class="num">Значення</th>
                  <th class="num">95% ДІ</th>
                  <th class="num">n</th>
                </tr>
              </thead>
              <tbody>
                {items.map((idx) => (
                  <tr>
                    <td class="code">{idx.code}</td>
                    <td>{idx.label}</td>
                    <td class="num">
                      <span class={`val ${idx.value > 100 ? 'up' : idx.value < 100 ? 'down' : ''}`}>
                        {idx.value.toFixed(1)}
                      </span>
                      {!idx.matchesReport && <span class="flag"> (звіт: {idx.reportValue})</span>}
                    </td>
                    <td class="num ci">
                      {idx.ciLow.toFixed(1)}–{idx.ciHigh.toFixed(1)}
                    </td>
                    <td class="num">{idx.n}</td>
                  </tr>
                ))}
              </tbody>
            </table>
          </ViewToggle>
        </section>
      );
    })
  }

  <p class="note" style="margin-top:1.5rem">
    Шкала: <b>100 = нейтральний рівень</b> (вище — переважання позитивних оцінок / зростання, нижче —
    негативних / скорочення). Зелені/червоні вуса — 95% довірчі інтервали. Зведений Індекс наукових
    можливостей (ІНМ) = <b>{inm?.value.toFixed(1)}</b>. Поряд з індексами є <a href="/data">не-індексні
    показники</a> (відсотки).
  </p>
</Layout>

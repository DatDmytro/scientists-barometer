---
import Layout from '../layouts/Layout.astro';
import ViewToggle from '../components/ViewToggle.astro';
import CatCrossTab from '../components/CatCrossTab.astro';
import block from '../data/block-categorization-2026.json';

const acts = block.activities; // дефолт: за спаданням БД%
const lbl = (n: number) => (n >= 10 ? String(Math.round(n)) : '');
---

<Layout
  title="Категоризація діяльності — Науковий Барометр"
  description="54 види діяльності науковця, класифіковані як дійсна наукова, корисна ненаукова чи безглузда."
>
  <h1>Категоризація діяльності</h1>
  <p class="lead">«{block.question}»</p>
  <p class="note">{block.note}</p>

  <div class="cat-summary">
    <div><b>{block.summary['ДНД']}</b> видів — переважно дійсна наукова</div>
    <div><b>{block.summary['КННД']}</b> — корисна ненаукова</div>
    <div><b>{block.summary['БД']}</b> — безглузда</div>
    <div><b>{block.fleissKappa}</b> Fleiss κ — помірна узгодженість</div>
    <div><b>{block.controversialCount}</b> суперечливих — розрив &lt; 20 в.п.</div>
  </div>

  <div class="cat-legend">
    <span><i class="swnd"></i>ДНД — дійсна наукова</span>
    <span><i class="swkn"></i>КННД — корисна ненаукова</span>
    <span><i class="swbd"></i>БД — безглузда</span>
    <span class="note">Pᵢ — узгодженість оцінювачів по виду (0…1)</span>
  </div>

  <div class="catsort">
    Сортувати:
    <select id="cat-sort">
      <option value="bd">за безглуздою (БД)</option>
      <option value="nd">за дійсною науковою (ДНД)</option>
      <option value="kn">за корисною ненауковою (КННД)</option>
      <option value="pi">за узгодженістю (Pᵢ)</option>
    </select>
  </div>

  <ViewToggle id="cat">
    <div slot="chart" id="cat-chart">
      {
        acts.map((a) => (
          <div class="actrow" data-nd={a.nd} data-kn={a.kn} data-bd={a.bd} data-pi={a.pi}>
            <div class="actname">
              {a.name}
              <span class="pi">Pᵢ={a.pi.toFixed(2)}</span>
              {a.controversial && <span class="contro"> · суперечливо</span>}
            </div>
            <div class="actbar">
              <span class="nd" style={`width:${a.nd}%`} title={`ДНД ${a.nd}%`}>{lbl(a.nd)}</span>
              <span class="kn" style={`width:${a.kn}%`} title={`КННД ${a.kn}%`}>{lbl(a.kn)}</span>
              <span class="bd" style={`width:${a.bd}%`} title={`БД ${a.bd}%`}>{lbl(a.bd)}</span>
            </div>
          </div>
        ))
      }
    </div>
    <table slot="table">
      <thead>
        <tr>
          <th>Вид діяльності</th>
          <th class="num">ДНД %</th>
          <th class="num">КННД %</th>
          <th class="num">БД %</th>
          <th class="num">Pᵢ</th>
          <th class="num">n</th>
        </tr>
      </thead>
      <tbody id="cat-tbody">
        {
          acts.map((a) => (
            <tr data-nd={a.nd} data-kn={a.kn} data-bd={a.bd} data-pi={a.pi}>
              <td>{a.name}</td>
              <td class="num">{a.nd.toFixed(1)}</td>
              <td class="num">{a.kn.toFixed(1)}</td>
              <td class="num" style={a.dominant === 'БД' ? 'font-weight:600;color:#bf4040' : ''}>
                {a.bd.toFixed(1)}
              </td>
              <td class="num">{a.pi.toFixed(3)}</td>
              <td class="num">{a.n}</td>
            </tr>
          ))
        }
      </tbody>
    </table>
  </ViewToggle>

  <p class="note" style="margin-top:1.5rem">
    Найбезглуздіші практики (за версією науковців): друк паперових варіантів, усне й письмове
    звітування, забезпечення формальних метрик (h-індекс, цитування). Pᵢ — наскільки одностайні
    оцінювачі щодо виду (складова Fleiss κ).
  </p>

  <section>
    <h2>Розрізи за демографією</h2>
    <p class="note" style="margin-top:-0.2rem">
      Обери вимір — побачиш % для кожного виду в розрізі груп. Який показник (ДНД/КННД/БД) і колір —
      залежить від селектора «Сортувати» вгорі (за замовч. БД, червоним). Темніше = вищий %.
    </p>
    <CatCrossTab block={block} />
  </section>

  <section>
    <h2>Коментарі до блоку ({block.comments.length})</h2>
    <p class="note">Відкриті коментарі респондентів до цього розділу анкети — дослівно, без редагування.</p>
    <ul class="qlist comments">
      {block.comments.map((c) => <li>{c}</li>)}
    </ul>
  </section>
</Layout>

<script>
  const sel = document.getElementById('cat-sort') as HTMLSelectElement | null;
  const chart = document.getElementById('cat-chart');
  const tbody = document.getElementById('cat-tbody');
  function sortContainer(container: HTMLElement | null, key: string) {
    if (!container) return;
    const rows = Array.from(container.children) as HTMLElement[];
    rows.sort((a, b) => parseFloat(b.dataset[key] || '0') - parseFloat(a.dataset[key] || '0'));
    rows.forEach((r) => container.appendChild(r));
  }
  // Перемикання показника теплокарти (ДНД/КННД/БД) — числа й колір клітинок
  const COLORS: Record<string, number[]> = { nd: [74, 140, 92], kn: [138, 175, 196], bd: [191, 64, 64] };
  function applyMetric(cat: string) {
    const [r, g, b] = COLORS[cat];
    document.querySelectorAll<HTMLElement>('.hm').forEach((cell) => {
      const raw = cell.dataset[cat];
      if (raw === undefined || raw === '') {
        cell.textContent = '·';
        cell.style.background = '';
        cell.style.color = 'var(--muted)';
        cell.classList.remove('hi');
        return;
      }
      const val = parseFloat(raw);
      const a = Math.min(val / 70, 1) * 0.85;
      cell.textContent = String(Math.round(val));
      cell.style.background = `rgba(${r},${g},${b},${a.toFixed(2)})`;
      cell.style.color = '';
      cell.classList.toggle('hi', a > 0.45);
    });
  }

  sel?.addEventListener('change', () => {
    const key = sel.value;
    sortContainer(chart, key);
    sortContainer(tbody, key);
    document.querySelectorAll('.ct-pane tbody').forEach((tb) => sortContainer(tb as HTMLElement, key));
    if (key === 'nd' || key === 'kn' || key === 'bd') applyMetric(key);
  });
</script>

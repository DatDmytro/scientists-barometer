---
import Layout from '../layouts/Layout.astro';
import IndicesChart from '../components/IndicesChart.astro';
import ResCrossTab from '../components/ResCrossTab.astro';
import SuffCrossTab from '../components/SuffCrossTab.astro';
import block from '../data/block-resources-2026.json';
import wave from '../data/wave-2026.json';

const provIdx = wave.indices.filter((i) => i.dimension === 'Поточна забезпеченість');
const dynIdx = wave.indices.filter((i) => i.dimension === 'Динаміка забезпеченості');
const w = block.war;
---

<Layout
  title="Забезпеченість ресурсами — Науковий Барометр"
  description="Наскільки науковці забезпечені фінансуванням, обладнанням і часом; нестача сну/відпочинку; втрати через війну."
>
  <h1>Забезпеченість ресурсами</h1>
  <p class="lead">«{block.question}»</p>

  <section>
    <h2>Поточна забезпеченість (ІНМ)</h2>
    <div class="cat-summary">
      <div><b class="big down">{block.inmIntegral}</b> ІНМ — інтегральний Індекс наукових можливостей (100 = нейтр.)</div>
      <div><b>{block.provision[0].unprovidedPct}%</b> незабезпечені фінансуванням ({block.provision[0].criticalPct}% критично)</div>
    </div>
    <IndicesChart indices={provIdx} />
    <table>
      <thead><tr><th>Ресурс</th><th class="num">Індекс</th><th class="num">Незабезпечені %</th><th class="num">з них критично</th></tr></thead>
      <tbody>
        {block.provision.map((p) => (
          <tr>
            <td>{p.label}</td>
            <td class="num"><b>{p.index}</b></td>
            <td class="num">{p.unprovidedPct}</td>
            <td class="num">{p.criticalPct}</td>
          </tr>
        ))}
      </tbody>
    </table>
  </section>

  <section>
    <h2>Динаміка забезпеченості</h2>
    <p class="note" style="margin-bottom:0.5rem">Як змінюється забезпеченість (індекс; 100 = без змін).</p>
    <IndicesChart indices={dynIdx} />
    <p class="note">Усі шість індексів динаміки <b>нижчі за 100</b> — забезпеченість погіршується за всіма ресурсами.</p>
  </section>

  <section>
    <h2>Достатність часу</h2>
    <div class="catsort">
      Показати:
      <select id="suf-metric">
        <option value="insuf">кому недостатньо (червоним)</option>
        <option value="suf">кому достатньо (зеленим)</option>
      </select>
    </div>
    <table class="dist">
      <tbody>
        {block.sufficiency.map((s) => (
          <tr>
            <td class="opt">{s.label}</td>
            <td class="barcell"><div class="bar"><span class="sufbar" data-insuf={s.insufficientPct} data-suf={s.sufficientPct} style={`width:${s.insufficientPct}%;background:#bf4040`}></span></div></td>
            <td class="pct sufpct" data-insuf={s.insufficientPct} data-suf={s.sufficientPct}>{s.insufficientPct}%</td>
            <td class="nn">крит. недост. {s.criticalPct}%</td>
          </tr>
        ))}
      </tbody>
    </table>

    <h3 style="font-size:0.96rem;margin:1.4rem 0 0.3rem;color:var(--ink)">Розрізи за демографією</h3>
    <p class="note" style="margin-top:0">Та сама метрика (недостатньо / достатньо) у розрізі груп. Темніше = вищий %.</p>
    <SuffCrossTab block={block} />
  </section>

  <section>
    <h2>Втрати через війну</h2>
    <div class="cat-summary">
      <div><b class="big down">{w.meanPct}%</b> робочого часу втрачається через обстріли, тривоги, відключення (медіана {w.medianPct}%)</div>
    </div>
  </section>

  <section>
    <h2>Розрізи за демографією</h2>
    <div class="catsort">
      Показати:
      <select id="prov-metric">
        <option value="unprov">хто незабезпечений (червоним)</option>
        <option value="prov">хто забезпечений (зеленим)</option>
      </select>
    </div>
    <p class="note" style="margin-top:0">% у групі для обраної метрики, по кожному ресурсу. Темніше = вищий %.</p>
    <ResCrossTab block={block} />
  </section>

  <section>
    <h2>Коментарі до блоку ({block.comments.length})</h2>
    <p class="note">Відкриті коментарі респондентів до цього розділу анкети — дослівно, без редагування.</p>
    <ul class="qlist comments">
      {block.comments.map((c) => <li>{c}</li>)}
    </ul>
  </section>
</Layout>

<script>
  // Перемикання достатності часу: insuf (червоний) ⇄ suf (зелений) — бари + теплокарта
  const sel = document.getElementById('suf-metric') as HTMLSelectElement | null;
  function applySuf(metric: string) {
    const [r, g, b] = metric === 'suf' ? [74, 140, 92] : [191, 64, 64];
    document.querySelectorAll<HTMLElement>('.sufbar').forEach((bar) => {
      const v = parseFloat(bar.dataset[metric] || '0');
      bar.style.width = v + '%';
      bar.style.background = `rgb(${r},${g},${b})`;
    });
    document.querySelectorAll<HTMLElement>('.sufpct').forEach((p) => {
      p.textContent = (p.dataset[metric] || '0') + '%';
    });
    document.querySelectorAll<HTMLElement>('.sm').forEach((cell) => {
      const raw = cell.dataset[metric];
      if (raw === undefined || raw === '') {
        cell.textContent = '·';
        cell.style.background = '';
        cell.style.color = 'var(--muted)';
        cell.classList.remove('hi');
        return;
      }
      const val = parseFloat(raw);
      const a = Math.min(val / 80, 1) * 0.85;
      cell.textContent = String(Math.round(val));
      cell.style.background = `rgba(${r},${g},${b},${a.toFixed(2)})`;
      cell.style.color = '';
      cell.classList.toggle('hi', a > 0.45);
    });
  }
  sel?.addEventListener('change', () => applySuf(sel.value));

  // Перемикання забезпеченості: unprov (червоний) ⇄ prov (зелений) — теплокарта розрізів
  const provSel = document.getElementById('prov-metric') as HTMLSelectElement | null;
  function applyProv(metric: string) {
    const [r, g, b] = metric === 'prov' ? [74, 140, 92] : [191, 64, 64];
    document.querySelectorAll<HTMLElement>('.pm').forEach((cell) => {
      const raw = cell.dataset[metric];
      if (raw === undefined || raw === '') {
        cell.textContent = '·';
        cell.style.background = '';
        cell.style.color = 'var(--muted)';
        cell.classList.remove('hi');
        return;
      }
      const val = parseFloat(raw);
      const a = Math.min(val / 80, 1) * 0.85;
      cell.textContent = String(Math.round(val));
      cell.style.background = `rgba(${r},${g},${b},${a.toFixed(2)})`;
      cell.style.color = '';
      cell.classList.toggle('hi', a > 0.45);
    });
  }
  provSel?.addEventListener('change', () => applyProv(provSel.value));
</script>

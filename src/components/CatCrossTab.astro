---
// Теплокарта БД% у розрізі демографій: рядки = види діяльності (за спаданням загального БД%),
// колонки = групи обраної демографії, клітинка = % у групі, хто вважає вид «безглуздим».
// Селектор демографії — CSS-only (reuse .ct-* + id ct-<dim>, як у мотивації). Придушення n<5.
interface Act { name: string; bd: number; }
interface Group { value: string; n: number; }
interface Dim { id: string; label: string; groups: Group[]; }
const { block } = Astro.props as {
  block: {
    activities: Act[];
    crosstabDims: Dim[];
    crosstab: Record<string, Record<string, { n: number; bd: Record<string, number | null> }>>;
  };
};
const acts = block.activities; // вже відсортовано за загальним БД%
const alpha = (p: number) => Math.min(p / 70, 1) * 0.85;
---

<div class="crosstab">
  {block.crosstabDims.map((d, i) => (
    <input type="radio" class="ct-r" name="ct-dim" id={`ct-${d.id}`} checked={i === 0} />
  ))}
  <div class="ct-tabs">
    {block.crosstabDims.map((d) => (
      <label for={`ct-${d.id}`}>{d.label}</label>
    ))}
  </div>

  {block.crosstabDims.map((d) => (
    <div class="ct-pane" data-dim={d.id}>
      <div class="ct-scroll">
        <table class="ct-table">
          <thead>
            <tr>
              <th>Вид діяльності · БД%</th>
              {d.groups.map((g) => (
                <th>{g.value}<br /><span class="ct-n">n={g.n}</span></th>
              ))}
            </tr>
          </thead>
          <tbody>
            {acts.map((a) => (
              <tr>
                <td>{a.name}</td>
                {d.groups.map((g) => {
                  const p = block.crosstab[d.id][g.value].bd[a.name];
                  if (p === null || p === undefined) {
                    return <td class="ct-cell" style="color:var(--muted)">·</td>;
                  }
                  const A = alpha(p);
                  return (
                    <td class={`ct-cell${A > 0.45 ? ' hi' : ''}`} style={`background:rgba(191,64,64,${A.toFixed(2)})`}>
                      {Math.round(p)}
                    </td>
                  );
                })}
              </tr>
            ))}
          </tbody>
        </table>
      </div>
      <p class="note" style="margin-top:0.5rem">
        Числа — % у групі, хто вважає вид <b>безглуздим</b> (БД). «·» — недостатньо даних (n &lt; 5).
        Темніше = вищий %.
      </p>
    </div>
  ))}
</div>

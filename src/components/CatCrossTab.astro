---
// Теплокарта розрізів: рядки = види (сортовані), колонки = групи демографії.
// Клітинка несе всі 3 % (data-nd/kn/bd); показує категорію, обрану селектором «Сортувати»
// (за замовч. БД — червоним). Перемикання метрики/кольору — інлайн-скриптом на сторінці.
// Селектор демографії — CSS-only (reuse .ct-* + id ct-<dim>). Придушення n<5 → «·».
interface Act { name: string; nd: number; kn: number; bd: number; pi: number; }
interface Cell { nd: number; kn: number; bd: number; }
interface Group { value: string; n: number; }
interface Dim { id: string; label: string; groups: Group[]; }
const { block } = Astro.props as {
  block: {
    activities: Act[];
    crosstabDims: Dim[];
    crosstab: Record<string, Record<string, { n: number; cells: Record<string, Cell | null> }>>;
  };
};
const acts = block.activities;
const alpha = (p: number) => Math.min(p / 70, 1) * 0.85;
---

<div class="crosstab">
  {block.crosstabDims.map((d, i) => (
    <input type="radio" class="ct-r" name="ct-dim" id={`ct-${d.id}`} checked={i === 0} />
  ))}
  <div class="ct-tabs">
    {block.crosstabDims.map((d) => (
      <label for={`ct-${d.id}`}>{d.label}</label>
    ))}
  </div>

  {block.crosstabDims.map((d) => (
    <div class="ct-pane" data-dim={d.id}>
      <div class="ct-scroll">
        <table class="ct-table">
          <thead>
            <tr>
              <th>Вид діяльності · %</th>
              {d.groups.map((g) => (
                <th>{g.value}<br /><span class="ct-n">n={g.n}</span></th>
              ))}
            </tr>
          </thead>
          <tbody>
            {acts.map((a) => (
              <tr data-nd={a.nd} data-kn={a.kn} data-bd={a.bd} data-pi={a.pi}>
                <td>{a.name}</td>
                {d.groups.map((g) => {
                  const c = block.crosstab[d.id][g.value].cells[a.name];
                  if (!c) {
                    return <td class="ct-cell hm" data-nd="" data-kn="" data-bd="" style="color:var(--muted)">·</td>;
                  }
                  const A = alpha(c.bd);
                  return (
                    <td class={`ct-cell hm${A > 0.45 ? ' hi' : ''}`} data-nd={c.nd} data-kn={c.kn} data-bd={c.bd}
                        style={`background:rgba(191,64,64,${A.toFixed(2)})`}>{c.bd}</td>
                  );
                })}
              </tr>
            ))}
          </tbody>
        </table>
      </div>
      <p class="note" style="margin-top:0.5rem">
        Числа — % у групі для <b>обраної категорії</b> (селектор «Сортувати»): ДНД (зелений) /
        КННД (синій) / БД (червоний). «·» — недостатньо даних (n &lt; 5). Темніше = вищий %.
      </p>
    </div>
  ))}
</div>
